{
    "extends": "@tsconfig/svelte/tsconfig.json",
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "types": ["node"],
        "verbatimModuleSyntax": true
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/ts/**/*",
        "resources/svelte/**/*.ts",
        "resources/svelte/**/*.svelte",
        "vite.config.ts",
        "svelte.config.ts"
    ]
}
