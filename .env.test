APP_NAME=LightSchool
APP_ENV=testing
APP_KEY=base64:9Xd/hhN9YKytfSC2ZL7A+s+INP+5yGTY5EMOf+EzWMI=
APP_DEBUG=true
APP_URL=http://apache:80

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=mariadb
DB_HOST=db
DB_PORT=3306
DB_DATABASE=lightschool
DB_USERNAME=lightschool
DB_PASSWORD=lightschool

# ─── Session / Cache / Queue ──────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_COOKIE=lightschool_session
CACHE_STORE=array
QUEUE_CONNECTION=database

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=debug

# ─── Mail (Mailpit) ───────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_ENCRYPTION=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@lightschool.test
MAIL_FROM_NAME="LightSchool Test"

# ─── LightSchool specific ─────────────────────────────────────────────────────
SECURE_DIR=/var/lightschool/secure
ALLOW_USER_UPLOADS=true
